import torch.nn as nn

class BigramNeuralNet(nn.Module):
    def __init__(self, vocab_size, embedding_dim):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embedding_dim)
        self.linear = nn.Linear(embedding_dim, vocab_size)

    def forward(self, x):
        # x is a tensor of character indices
        embedded = self.embedding(x)  # convert to vectors
        logits = self.linear(embedded)  # pass through linear layer
        return logits

vocab_size = 27
embedding_dim = 2  # start small for visualization
model = BigramNeuralNet(vocab_size, embedding_dim)

