embedding = nn.Embedding(vocab_size, embedding_dim)\n","        self.linear = nn.Linear(embedding_dim, vocab_size)\n","\n","    def forward(self, x):\n","        # x is a tensor of character indices\n","        embedded = self.embedding(x)  # convert to vectors\n","        logits = self.linear(embedded)  # pass through linear layer\n","        return logits\n","\n","vocab_size = 27\n","embedding_dim = 2  # start small for visualization\n","model = BigramNeuralNet(vocab_size, embedding_dim)"],"metadata":{"id":"wYz-jLRD94ff"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# 5. Prepare Training Data\n","xs, ys = [], []\n","\n","for w in words:\n","    chs = ['.'] + list(w) + ['.']\n","    for ch1, ch2 in zip(chs, chs[1:]):\n","        ix1 = stoi[ch1]\n","        ix2 = stoi[ch2]\n","        xs.append(ix1)\n","        ys.append(ix2)\n","\n","xs = torch.tensor(xs)  # input characters\n","ys = torch.tensor(ys)  # target characters\n","\n","print(xs.shape)  # [228146]\n","print(ys.shape)  # [228146]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"a1buSZK5sSq4","executionInfo":{"status":"ok","timestamp":1780481960089,"user_tz":-360,"elapsed":223,"user":{"displayName":"azwad abid","userId":"17648209778116814404"}},"outputId":"7c190528-5114-47bf-a22e-f36220b5e431"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["torch.Size([228146])\n","torch.Size([228146])\n"]}]},{"cell_type":"code","source":["# Create optimizer\n","#6. Setup Training\n","optimizer = torch.optim.SGD(model.parameters(), lr=0.1)\n","loss_fn = nn.CrossEntropyLoss() # softmax + log + mean"],"metadata":{"id":"ttQyyI2MsZFn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["for epoch in range(100):\n","    # Forward pass\n","    logits = model(xs)  # predictions for all 228k pairs\n","    loss = loss_fn(logits, ys)  # how wrong are we\n","\n","    # Backward pass\n","    optimizer.zero_grad()  # reset gradients\n","    loss